{
  "name": "swing-ai",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/server",
    "packages/app"
  ],
  "scripts": {
    "server:dev": "npm run dev --workspace=@swing-ai/server",
    "server:build": "npm run build --workspace=@swing-ai/server",
    "server:start": "npm run start --workspace=@swing-ai/server",
    "app:start": "npm run start --workspace=@swing-ai/app",
    "app:ios": "npm run ios --workspace=@swing-ai/app",
    "app:android": "npm run android --workspace=@swing-ai/app",
    "app:web": "npm run web --workspace=@swing-ai/app",
    "app:prebuild": "npm run prebuild --workspace=@swing-ai/app",
    "db:push": "npm run db:push --workspace=@swing-ai/server",
    "lint": "npm run lint --workspace=@swing-ai/app"
  },
  "devDependencies": {
    "typescript": "~5.9.2"
  }
}
