{
  "name": "@swing-ai/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx --tsconfig tsconfig.json src/index.ts",
    "build": "esbuild src/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist --alias:@swing-ai/shared=../shared",
    "start": "NODE_ENV=production node dist/index.js",
    "db:push": "drizzle-kit push",
    "model:seed:r2": "tsx --tsconfig tsconfig.json scripts/seed-model-artifacts-to-r2.ts",
    "analysis:backfill-video-paths": "tsx --tsconfig tsconfig.json scripts/backfill-analysis-video-paths.ts",
    "analysis:quick": "node scripts/quick_analysis.js scripts/quick_analysis.config.json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1013.0",
    "@aws-sdk/s3-request-presigner": "^3.1013.0",
    "@swing-ai/shared": "*",
    "bcryptjs": "^3.0.3",
    "connect-pg-simple": "^10.0.0",
    "drizzle-orm": "^0.39.3",
    "express": "^5.0.1",
    "express-session": "^1.19.0",
    "multer": "^2.0.2",
    "pg": "^8.16.3",
    "ws": "^8.18.0",
    "zod": "^3.24.2",
    "zod-validation-error": "^3.4.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.2",
    "@types/multer": "^2.0.0",
    "drizzle-kit": "^0.31.4",
    "esbuild": "^0.25.0",
    "tsx": "^4.20.6",
    "typescript": "~5.9.2"
  }
}
