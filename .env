# ==============================
# Video storage mode (videoStorageMode)
# ==============================
# Local machine default: filesystem
# Replit production default: r2
# Replit dev can be toggled: filesystem or r2
# Valid values: filesystem | r2
# This is stored as part of app_settings in the database.
# Cloudflare R2 (required if videoStorageMode=r2)
# ==============================
R2_ENDPOINT=https://8cd1b77f771d1df564e004d5ac5d80e0.r2.cloudflarestorage.com
R2_REGION=auto
R2_BUCKET=swingai
R2_PLAYER_VIDEO_FOLDER=video
R2_PLAYER_AVATAR_FOLDER=avatar
R2_PLAYER_MODEL_FOLDER=model
R2_ACCESS_KEY_ID=eb9c8de0e7580980b715e7598e65f2a9
R2_SECRET_ACCESS_KEY=1cea0cd73320a731c1f75b023bdb7bebd702286a4929b6928b365c83fdaaf6e6

# ==============================
# Model artifact storage mode (modelArtifactStorageMode)
# ==============================
# Controls classifier + pose artifact publish/download behavior.
# Valid values: filesystem | r2
# If omitted, the server falls back to videoStorageMode.
# Local machine default: filesystem
# Replit production: set to r2
MODEL_ARTIFACT_STORAGE_MODE=r2