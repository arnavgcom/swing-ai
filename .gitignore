# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# ─── Dependencies ────────────────────────────────────────────
node_modules/

# ─── Expo / Metro ────────────────────────────────────────────
.expo/
web-build/
.metro-health-check*

# ─── Native build artifacts ──────────────────────────────────
ios/
android/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# ─── macOS ────────────────────────────────────────────────────
.DS_Store
*.pem

# ─── Environment / secrets ───────────────────────────────────
.env*.local

# ─── TypeScript build info ───────────────────────────────────
*.tsbuildinfo
.vercel

# ─── Videos ──────────────────────────────────────────────────
*.mp4

# ─── Python ──────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.venv
venv/
ENV/
env.bak/
venv.bak/

# ─── Packages: server ────────────────────────────────────────
packages/server/dist/
packages/server/uploads/
server_dist/

# ─── Packages: app (auto-generated) ─────────────────────────
# expo-env.d.ts is also in packages/app/.gitignore

# ─── Logs ────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Debug ───────────────────────────────────────────────────
npm-debug.*
yarn-debug.*
yarn-error.*
